{
  "name": "@jsse/pbfont",
  "type": "module",
  "version": "0.3.4",
  "author": "jessekrubin",
  "license": "MIT",
  "homepage": "https://github.com/jessekrubin/pbfont#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jessekrubin/pbfont.git"
  },
  "bugs": {
    "url": "https://github.com/jessekrubin/pbfont/issues"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./bundle": {
      "import": {
        "types": "./dist/bundle.d.ts",
        "default": "./dist/bundle.js"
      },
      "require": {
        "types": "./dist/bundle.d.cts",
        "default": "./dist/bundle.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "license",
    "package.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm gen && tsdown --dts && tsc && publint",
    "build-fast": "tsdown",
    "build:tsc": "tsc",
    "change": "changeset",
    "check": "eslint . && prettier --check .",
    "ci:publish": "pnpm publish",
    "ci:version": "changeset version && pnpm install && pnpm fmt",
    "release": "changeset version && git add -u && git commit -m \"chore: release\" && git push && git push --tags && pnpm publish",
    "cov": "vitest run --coverage",
    "fmt": "prettier --write src package.json",
    "fmtc": "prettier --check .",
    "gen": "npx buf generate proto && pnpm run fmt",
    "gen:clean": "npx buf generate proto --clean",
    "lint": "eslint .",
    "prepack": "npm run build",
    "test": "vitest run",
    "tsc": "tsc -p tsconfig.json",
    "tsup": "tsdown",
    "typecheck": "tsc --noEmit",
    "vitest": "vitest --config vitest.config.ts --run",
    "vitest:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.1"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.71.0",
    "@bufbuild/protoc-gen-es": "^2.12.1",
    "@changesets/cli": "^2.31.0",
    "@jsse/eslint-config": "^0.8.1",
    "@jsse/tsconfig": "^0.5.1",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "prettier": "~3.9.1",
    "publint": "^0.3.21",
    "tsdown": "^0.22.3",
    "tsx": "~4.22.4",
    "typescript": "~6.0.3",
    "vitest": "~4.1.9"
  }
}
